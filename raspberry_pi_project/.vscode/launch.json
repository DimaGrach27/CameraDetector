{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Raspberry Pi (gdbserver)",
      "type": "cppdbg",
      "request": "launch",
      "program": "${workspaceFolder}/build/rpi-debug-local/Camera_tracking",
      "cwd": "${workspaceFolder}",
      "MIMode": "gdb",
      "miDebuggerPath": "/opt/homebrew/bin/aarch64-linux-gnu-gdb",
      "miDebuggerServerAddress": "192.168.0.107:2345",
      "preLaunchTask": "run-gdbserver-rpi",
      "stopAtEntry": false,
      "externalConsole": false,
      "setupCommands": [
        {
          "description": "Enable pretty printing",
          "text": "-enable-pretty-printing",
          "ignoreFailures": true
        },
        {
          "description": "Set sysroot for symbols/libs",
          "text": "set sysroot /Users/dhrachov/rpi-sysroot",
          "ignoreFailures": true
        }
      ]
    }
  ]
}